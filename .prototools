# https://moonrepo.dev/docs/proto/config
moon = "2.1.1"
go = "1.26.1"
python = "3.14.3"
terraform = "1.14.7"
buf = "1.66.1"
zarf = "0.74.0"
grafanactl = "0.1.9"
golangci-lint = "2.11.3"
kind = "0.31.0"
clusterctl = "1.12.3"
actionlint = "1.7.11"
hadolint = "2.14.0"
yq = "4.52.4"
pint = "0.79.0"
sloth = "0.15.0"

[plugins.tools]
actionlint = "source:.proto/plugins/actionlint.toml"
terraform = "https://raw.githubusercontent.com/theomessin/proto-toml-plugins/master/terraform.toml"
buf = "https://raw.githubusercontent.com/stk0vrfl0w/proto-toml-plugins/main/plugins/buf.toml"
golangci-lint = "https://raw.githubusercontent.com/b4nst/proto-plugins/refs/heads/main/toml/golangci-lint.toml"
zarf = "source:.proto/plugins/zarf.toml"
hadolint = "source:.proto/plugins/hadolint.toml"
grafanactl = "source:.proto/plugins/grafanactl.toml"
kind = "source:.proto/plugins/kind.toml"
clusterctl = "source:.proto/plugins/clusterctl.toml"
yq = "source:.proto/plugins/yq.toml"
pint = "source:.proto/plugins/pint.toml"
sloth = "source:.proto/plugins/sloth.toml"
